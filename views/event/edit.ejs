<%- include('../partials/header.ejs')%>

<div class="form-container">
  <h2>Edit Event</h2>
  <br />

  <form method="POST" action="/events/<%= event._id%>?_method=PUT">
    <div class="form-group">
      <label for="category">Category</label>
      <select name="category" id="category" required>
        <option value="<%= event.category%>"><%= event.category%></option>
        <option value="Car Race">Car Race</option>
        <option value="Car Shows">Car Shows</option>
        <option value="Car Community Events">Car Community Events</option>
        <option value="Car Meet Up">Car Meet Up</option>
        <option value="Car Rally">Car Rally</option>
        <option value="Car Unveiling">Car Unveiling</option>
      </select>

      <label for="title">Title</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= event.title%>"
        required
      />

      <label for="details">Details</label>
      <input
        type="text"
        id="details"
        name="details"
        value="<%= event.details%>"
        required
      />

      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        value="<%= event.location%>"
        required
      />

      <label for="startDate">Start</label>
      <input
        type="datetime-local"
        id="startDate"
        name="startDate"
        value="<%= event.startDate %>"
        required
      />

      <label for="endDate">End</label>
      <input
        type="datetime-local"
        id="endDate"
        name="endDate"
        value="<%= event.endDate %>"
        required
      />

      <button type="submit">Update Event</button>
    </div>
  </form>
</div>
<%- include('../partials/footer.ejs')%>
